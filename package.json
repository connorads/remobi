{
	"name": "muxi",
	"version": "0.1.0",
	"description": "Monitor and control your coding agents from your phone. Touch controls for tmux over the web.",
	"type": "module",
	"bin": {
		"muxi": "./dist/cli.mjs"
	},
	"exports": {
		".": {
			"types": "./dist/src/index.d.mts",
			"default": "./dist/src/index.mjs"
		},
		"./config": {
			"types": "./dist/src/config.d.mts",
			"default": "./dist/src/config.mjs"
		},
		"./types": {
			"types": "./dist/src/types.d.mts"
		}
	},
	"files": ["dist/", "styles/", "src/pwa/icons/", "README.md", "CHANGELOG.md", "LICENSE"],
	"engines": {
		"node": ">=22.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/connorads/muxi.git"
	},
	"homepage": "https://github.com/connorads/muxi",
	"bugs": "https://github.com/connorads/muxi/issues",
	"scripts": {
		"build:overlay": "tsx scripts/build-overlay.ts",
		"build:dist": "tsdown && pnpm run build:overlay",
		"build": "tsx cli.ts build",
		"check": "biome check .",
		"check:fix": "biome check --fix .",
		"lint:knip": "knip",
		"lint:ox": "oxlint --import-plugin --promise-plugin",
		"lint:publint": "publint",
		"lint:typos": "typos",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"prepublishOnly": "pnpm test && pnpm run check && pnpm run lint:ox && pnpm run lint:knip && pnpm run lint:publint && pnpm run build:dist"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"esbuild": "^0.25.0",
		"@happy-dom/global-registrator": "^20.6.1",
		"@types/node": "^22.0.0",
		"@types/ws": "^8.18.0",
		"knip": "^5.85.0",
		"oxlint": "^1.50.0",
		"publint": "^0.3.17",
		"tsdown": "^0.20.0",
		"tsx": "^4.19.0",
		"typescript": "^5.9.3",
		"vitest": "^3.0.0"
	},
	"license": "MIT",
	"author": "Connor",
	"keywords": [
		"ttyd",
		"tmux",
		"terminal",
		"mobile",
		"overlay",
		"touch",
		"node",
		"agents",
		"claude",
		"remote",
		"pwa"
	],
	"dependencies": {
		"@hono/node-server": "^1.14.0",
		"@hono/node-ws": "^1.1.0",
		"hono": "^4.7.0",
		"valibot": "^1.2.0",
		"ws": "^8.18.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
	}
}
