{
	"name": "webmux",
	"version": "0.1.0",
	"description": "Mobile-friendly terminal overlay for ttyd + tmux",
	"type": "module",
	"bin": {
		"webmux": "./cli.ts"
	},
	"exports": {
		".": "./src/index.ts",
		"./config": "./src/config.ts",
		"./types": "./src/types.ts"
	},
	"files": ["src/", "styles/", "cli.ts", "build.ts", "README.md", "CHANGELOG.md", "LICENSE"],
	"engines": {
		"bun": ">=1.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/connorads/webmux.git"
	},
	"homepage": "https://github.com/connorads/webmux",
	"bugs": "https://github.com/connorads/webmux/issues",
	"scripts": {
		"build": "bun run cli.ts build",
		"check": "biome check .",
		"check:fix": "biome check --fix .",
		"lint:ox": "oxlint --import-plugin --promise-plugin",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"prepublishOnly": "bun test && bun run check && bun run lint:ox"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@happy-dom/global-registrator": "^20.6.1",
		"bun-types": "^1.3.9",
		"happy-dom": "^15.0.0",
		"oxlint": "^1.50.0",
		"typescript": "^5.9.3"
	},
	"license": "MIT",
	"author": "Connor",
	"keywords": ["ttyd", "tmux", "terminal", "mobile", "overlay", "touch", "bun"],
	"trustedDependencies": ["@biomejs/biome"],
	"dependencies": {
		"valibot": "^1.2.0"
	}
}
